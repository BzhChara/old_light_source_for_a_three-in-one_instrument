<RelativeLayout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
    tools:context="com.zkzk.ecas.activity.SetupActivity" >

    <include
        android:id="@+id/title"
        layout="@layout/title" />

    <TextView
        android:id="@+id/tv_sys_set"
        style="@style/text_set"
        android:layout_width="360dp"
        android:layout_height="10dp"
        android:layout_below="@id/title"
        android:layout_marginLeft="39dp"
        android:layout_marginTop="12dp"
        android:background="@color/bg_gray"
        android:gravity="center"
        android:text="@string/system_setup"
        android:textSize="@dimen/text_size"
        android:visibility="invisible" />

    <RadioGroup
        android:id="@+id/rg_setup"
        android:layout_width="360dp"
        android:layout_height="match_parent"
        android:layout_alignParentLeft="true"
        android:layout_below="@+id/tv_sys_set"
        android:layout_marginBottom="160dp"
        android:layout_marginLeft="38dp"
        android:layerType="software"
        android:orientation="vertical" >

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed" />

        <RadioButton
            android:id="@+id/rb_species"
            style="@style/rb_setup"
            android:checked="true"
            android:drawableRight="@drawable/arrow"
            android:drawableStart="@drawable/normal_set"
            android:paddingLeft="80dp"
            android:paddingRight="15dp"
            android:saveEnabled="false"
            android:text="@string/a_normal_set" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed" />

        <RadioButton
            android:id="@+id/rb_sources"
            style="@style/rb_setup"
            android:checked="false"
            android:drawableStart="@drawable/wifi_set"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:saveEnabled="false"
            android:text="@string/a_wifi_set" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed" />



        <RadioButton
            android:id="@+id/rb_data_upload"
            style="@style/rb_setup"
            android:drawableStart="@drawable/upload"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:saveEnabled="false"
            android:text="@string/a_data_upload" />
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed" />

        <RadioButton
            android:id="@+id/rb_sys_param"
            style="@style/rb_setup"
            android:drawableStart="@drawable/self_info"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:saveEnabled="false"
            android:text="系统参数" />
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed" />

        <RadioButton
            android:id="@+id/rb_self_info"
            style="@style/rb_setup"
            android:drawableStart="@drawable/self_info"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:saveEnabled="false"
            android:text="@string/a_self_info" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed" />
    </RadioGroup>

    <View
        android:id="@+id/devider"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_below="@+id/title"
        android:layout_marginBottom="42dp"
        android:layout_marginTop="2dp"
        android:layout_toEndOf="@+id/rg_setup"
        android:background="#B2A8A7" />

    <FrameLayout
        android:id="@+id/fl_set"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/title"
        android:layout_above="@+id/bottom"
        android:layout_marginRight="38dp"
        android:layout_marginTop="2dp"
        android:layout_toEndOf="@+id/devider"
        android:background="@null" />

    <include
        android:id="@+id/bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        layout="@layout/bottom_bar" />

</RelativeLayout>
