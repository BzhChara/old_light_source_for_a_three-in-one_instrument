<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="600dp"
    android:layout_height="250dp"
    android:background="@color/bg"
    android:orientation="vertical" 
    >

    <TextView
        android:id="@+id/tv_dialog_wifi_title"
        style="@style/text_set"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="请输入“仪器实验室”的密码"
         />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bg_gray" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/bt_dialog_wifi_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:textSize="@dimen/text_size"
            android:textColor="#6DA0E5"
            android:text="@string/cancel" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            style="@style/text_set"
            android:textSize="@dimen/text_size"
            android:text="@string/input_psw" />

        <Button
            android:id="@+id/bt_dialog_wifi_join"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:textSize="@dimen/text_size"
            style="@style/text_set"
            android:text="@string/join"
            android:textColor="#6DA0E5" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bg_gray" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingRight="10dp" 
        android:gravity="center_vertical">
        <TextView 
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size"
            android:text="@string/password_"/>

        <EditText
            android:id="@+id/et_dialog_wifi_psw"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:ems="10"
            style="@style/text_set"
            android:background="@drawable/shape_border"
            android:hint="0000"
            android:inputType="textPassword" >
			
            <requestFocus />
        </EditText>

    </LinearLayout>

</LinearLayout>