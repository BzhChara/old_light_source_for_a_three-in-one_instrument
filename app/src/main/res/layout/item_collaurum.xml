<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:background="@null">

    <TextView
        android:id="@+id/tv_detect_type_useless2"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="5dp"
        android:gravity="center"
        android:text="@string/detect_proj" />

    <Spinner
        android:id="@+id/spinner_detect_proj"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_alignTop="@+id/tv_detect_type_useless2"
        android:layout_marginLeft="7dp"
        android:layout_toRightOf="@+id/tv_detect_type_useless2"
        android:background="@drawable/shape_border"
        android:dropDownHorizontalOffset="20dp"
        android:dropDownVerticalOffset="-50dp"
        android:popupBackground="#f0000000"
        android:spinnerMode="dropdown"
        android:tag="@string/proj" />

    <TextView
        android:id="@+id/tv_detect_rpoj_useless2"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_alignLeft="@+id/tv_detect_type_useless2"
        android:layout_below="@+id/tv_detect_type_useless2"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/specimen_type" />

    <Spinner
        android:id="@+id/spinner_detect_type"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_alignTop="@+id/tv_detect_rpoj_useless2"
        android:layout_marginLeft="7dp"
        android:layout_toRightOf="@+id/tv_detect_rpoj_useless2"
        android:background="@drawable/shape_border"
        android:dropDownHorizontalOffset="20dp"
        android:dropDownVerticalOffset="-50dp"
        android:popupBackground="#f0000000"
        android:spinnerMode="dropdown"
        android:tag="@string/proj" />
    
    <ImageView 
        android:id="@+id/iv_hump"
        android:layout_width="200dp"
        android:layout_height="160dp"
        android:layout_centerHorizontal="true"
        android:scaleType="fitXY"
        android:layout_below="@+id/spinner_detect_type"/>

   <TextView 
       android:id="@+id/tv_result"
       android:layout_width="200dp"
       android:layout_height="match_parent"
       android:layout_below="@+id/iv_hump"
       android:layout_alignParentBottom="true"
       android:layout_centerHorizontal="true"
       android:text="this is result"
       android:gravity="center"/>

</RelativeLayout>