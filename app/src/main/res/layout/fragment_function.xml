<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
    android:orientation="vertical"
    android:paddingLeft="@dimen/left_right" >

    <TextView
        style="@style/text_set"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="1dp"
        android:background="@drawable/shape_top_end_15"
        android:gravity="center"
        android:text="标曲录入"
        android:textSize="@dimen/text_size" />

    <TextView
        style="@style/text_set"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="1dp"
        android:background="@drawable/shape_top_end_15"
        android:gravity="left|center_vertical"
        android:text="请按顺序依次输入相对吸光度和对应的浓度值"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测项目"
            android:textSize="@dimen/text_size" />

        <Spinner
            android:id="@+id/sp_function_proj"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:popupBackground="#f0000000"
            android:spinnerMode="dropdown"
            android:tag="@string/proj" />

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="样品名"
            android:textSize="@dimen/text_size" />

        <TextView
            style="@style/text_set"
            android:id="@+id/tv_function_specimen"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:popupBackground="#f0000000"
            android:spinnerMode="dropdown"
            android:tag="@string/proj" />
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            />
         <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  类型"
            android:textSize="@dimen/text_size" />

        <Spinner
            android:id="@+id/sp_function_type"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:popupBackground="#f0000000"
            android:spinnerMode="dropdown" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/sv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
       	android:visibility="gone"
        android:layout_weight="1" >

        <LinearLayout
            android:id="@+id/ll_kvs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp" >
			<!--
            <include layout="@layout/function_item" />

            <include layout="@layout/function_item" />
			 -->

            <ImageButton
                android:id="@+id/ib_function_add"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/add" />
        </LinearLayout>
    </ScrollView>

    
    <LinearLayout 
        android:id="@+id/ll_kb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:gravity="center"
        android:visibility="visible"
        android:orientation="horizontal">
        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="斜率："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_function_k"
            style="@style/et_params"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:inputType="numberDecimal"
            android:ems="10"
            android:paddingLeft="10dp"
            android:hint="k（由吸光度计算浓度）" />
        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="截距："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_function_b"
            style="@style/et_params"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:inputType="numberSigned|numberDecimal"
            android:ems="10"
            android:paddingLeft="10dp"
            android:hint="b（由吸光度计算浓度）" />
        
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="浓度单位："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_function_unit"
            style="@style/et_params"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            android:text="mg/kg" >

            <requestFocus android:layout_height="match_parent" />
        </EditText>

        <Button
            android:id="@+id/bt_function_ok"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="60dp"
            android:background="@drawable/selector_button_red"
            android:text="确定"
            android:textColor="#ffffff"
            android:textSize="30sp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >
<!--        android:visibility="gone"-->

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="增加项目："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_proj"
            style="@style/et_params"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp" >

            <requestFocus android:layout_height="match_parent" />
        </EditText>

        <Button
            android:id="@+id/bt_add_proj"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:background="@drawable/selector_button_red"
            android:text="确定"
            android:textColor="#ffffff"
            android:textSize="30sp" />
<!--        android:visibility="gone"-->
        <Button
            android:id="@+id/bt_delete_proj"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="60dp"
            android:background="@drawable/selector_button_red"
            android:text="删除"
            android:textColor="#ffffff"
            android:textSize="30sp" />
    </LinearLayout>

</LinearLayout>
