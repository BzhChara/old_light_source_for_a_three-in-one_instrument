<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical" >

    <TextView
        android:id="@+id/tv_top"
        style="@style/text_set"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="1dp"
        android:background="@drawable/shape_top_end_15"
        android:gravity="center"
        android:text="@string/self_info"
        android:textSize="@dimen/text_size" />


    <TextView
        android:id="@+id/tv_set_version"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_top"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="50dp"
        android:text="@string/version" />

    <TextView
        android:id="@+id/tv_version"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/tv_set_version"
        android:layout_toRightOf="@+id/tv_set_version"
        android:text="" />

    <Button
        android:id="@+id/bt_upload"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_set_version"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="50dp"
        android:background="@null"
        android:text="@string/version_update" />

    <Button
        android:id="@+id/bt_more"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/bt_upload"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="50dp"
        android:background="@null"
        android:text="@string/more_product"
        android:visibility="visible" />

    

    <TextView
        android:id="@+id/tv_set_serial"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/bt_more"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="50dp"
        android:text="@string/serial_number_" />

    <TextView
        android:id="@+id/tv_serial"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/tv_set_serial"
        android:layout_toRightOf="@+id/tv_set_serial"
        android:textIsSelectable="true"
        android:text="" />

    <TextView
        android:id="@+id/tv_location"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_set_serial"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="50dp"
        android:text="" />
    
    <Button
        android:id="@+id/bt_fucus"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_location"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="50dp"
        android:background="@null"
        android:text="调焦"
        android:visibility="visible" />
    <Button
        android:id="@+id/bt_segment"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/bt_fucus"
        android:layout_alignBottom="@+id/bt_fucus"
        android:layout_marginLeft="40dp"
        android:background="@null"
        android:text="切片参数"
        android:visibility="visible" />
    <Button
        android:id="@+id/bt_instructs"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/bt_segment"
        android:layout_alignBottom="@+id/bt_fucus"
        android:layout_marginLeft="40dp"
        android:background="@null"
        android:text="指令调试"
        android:visibility="visible" />
</RelativeLayout>
