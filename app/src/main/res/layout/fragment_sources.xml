<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:paddingLeft="@dimen/left_right"
    android:paddingRight="@dimen/left_right" >

    <TextView
        style="@style/text_set"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="1dp"
        android:background="@drawable/shape_top_end_15"
        android:gravity="center"
        android:text="样品来源"
        android:textSize="@dimen/text_size" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            android:id="@+id/textView3"
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="来源单位："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_source_org"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            style="@style/et_params">

            <requestFocus android:layout_height="match_parent" />
        </EditText>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="企业代码："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_source_org_code"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            style="@style/et_params">

            <requestFocus android:layout_height="match_parent" />
        </EditText>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测类型："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_source_org_type"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            android:inputType="number"
            android:hint="1 代表种植业，2 代表畜禽业，3 代表水产业"
            android:text="1"
            style="@style/et_params">

            <requestFocus android:layout_height="match_parent" />
        </EditText>
    </LinearLayout>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="样品产地："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_source_addr"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            style="@style/et_params" >

            <requestFocus android:layout_height="match_parent" />
        </EditText>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  联系人  ："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_source_contact"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            style="@style/et_params" >

            <requestFocus android:layout_height="match_parent" />
        </EditText>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="联系方式："
            android:textSize="@dimen/text_size" />

        <EditText
            android:id="@+id/et_source_phone"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:ems="10"
            android:paddingLeft="10dp"
            style="@style/et_params" >

            <requestFocus android:layout_height="match_parent" />
        </EditText>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:gravity="top|end" >

        <Button
            android:id="@+id/bt_source_add"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="80dp"
            android:background="@drawable/selector_button_red"
            android:text="添加"
            android:layout_marginTop="10dp"
            android:textColor="#ffffff"
            android:textSize="30sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" >

        <TextView
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="   浏览    ："
            android:textSize="@dimen/text_size" />

        <Spinner
            android:id="@+id/sp_sources_scan"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="30dp"
            android:layout_weight="1"
            android:background="@drawable/shape_border"
            android:popupBackground="#f0000000"
            android:spinnerMode="dropdown"
            android:tag="@string/proj" />

        <Button
            android:id="@+id/bt_sources_delete"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="80dp"
            android:background="@drawable/selector_button_red"
            android:text="删除"
            android:textColor="#ffffff"
            android:textSize="30sp" />
    </LinearLayout>

</LinearLayout>