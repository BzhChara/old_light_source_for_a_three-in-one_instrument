<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >

    <TextView
        android:id="@+id/title"
        style="@style/text_set"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="1dp"
        android:background="@color/bg_gray"
        android:gravity="center"
        android:text="@string/ethnet_set"
        android:textSize="@dimen/text_size" />

    <TextView
        android:id="@+id/tv_eth_set"
        style="@style/text_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/title"
        android:layout_margin="15dp"
        android:text="@string/ethnet_set" />

    <RelativeLayout
        android:id="@+id/rl_ip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_below="@+id/tv_eth_set"
        android:layout_marginTop="50dp"
        android:paddingTop="30dp"
        android:paddingBottom="10dp"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="30dp"
        android:background="@drawable/ip_border" >
        <TextView
            android:id="@+id/tv_ip"
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_marginLeft="39dp"
            android:text="@string/ip_addr" />

        <com.zkzk.pra.ui.IPEditText
            android:id="@+id/ipet_ip"
            android:layout_width="400dp"
            android:layout_height="50dp"
            android:layout_alignBottom="@+id/tv_ip"
            android:layout_alignTop="@+id/tv_ip"
            android:layout_centerHorizontal="true" />

		<!-- 子网掩码 -->        
        <TextView
            android:id="@+id/tv_mask"
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_below="@+id/tv_ip"
            android:layout_marginTop="30dp"
            android:layout_marginLeft="39dp"
            android:text="@string/subnet_mask" />
        <com.zkzk.pra.ui.IPEditText
            android:id="@+id/ipet_mask"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/tv_mask"
            android:layout_alignBottom="@+id/tv_mask"
            android:layout_centerHorizontal="true"/>
<!-- 默认网关 -->
        <TextView
            android:id="@+id/tv_gatway"
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_below="@+id/tv_mask"
            android:layout_marginTop="30dp"
            android:layout_marginLeft="39dp"
            android:text="@string/default_gateway" />
        <com.zkzk.pra.ui.IPEditText
            android:id="@+id/ipet_gatway"
            android:layout_width="400dp"
            android:layout_height="50dp"
            android:layout_alignTop="@+id/tv_gatway"
            android:layout_alignBottom="@+id/tv_gatway"
            android:layout_centerHorizontal="true" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/rl_dns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_marginBottom="72dp"
        android:background="@drawable/ip_border"
        android:paddingBottom="10dp"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="30dp"
        android:paddingTop="30dp" >

        <TextView
            android:id="@+id/tv_dns_first"
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_marginLeft="39dp"
            android:text="@string/first_choise_dns_server" />

        <com.zkzk.pra.ui.IPEditText
            android:id="@+id/ipet_dns_first"
            android:layout_width="400dp"
            android:layout_height="50dp"
            android:layout_alignTop="@+id/tv_dns_first"
            android:layout_alignBottom="@+id/tv_dns_first"
            android:layout_centerHorizontal="true" >
        </com.zkzk.pra.ui.IPEditText>

        <TextView
            android:id="@+id/tv_dns_second"
            style="@style/text_set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_below="@+id/tv_dns_first"
            android:layout_marginLeft="39dp"
            android:layout_marginTop="30dp"
            android:text="@string/standby_choise_dns_server" />

        <com.zkzk.pra.ui.IPEditText
            android:id="@+id/ipet_dns_second"
            android:layout_width="400dp"
            android:layout_height="50dp"
            android:layout_alignTop="@+id/tv_dns_second"
            android:layout_alignBottom="@+id/tv_dns_second"
            android:layout_centerHorizontal="true" >
        </com.zkzk.pra.ui.IPEditText>
    </RelativeLayout>

    <RadioGroup
        android:id="@+id/rg_dns"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignLeft="@+id/rg_ip"
        android:layout_above="@+id/rl_dns"
        android:layout_marginBottom="-24dp"
        android:layout_marginTop="84dp"
        android:background="@color/bg_w" >

        <RadioButton
            android:id="@+id/rb_dns_auto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_get_dns_server_addr"
            android:textSize="28sp" />

        <RadioButton
            android:id="@+id/rb_dns_follow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/use_the_follow_dns_server_addr"
            android:textSize="28sp" />
    </RadioGroup>

    <RadioGroup
        android:id="@+id/rg_ip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignLeft="@+id/rl_ip"
        android:layout_above="@+id/rl_ip"
        android:layout_marginBottom="-75dp"
        android:layout_marginLeft="33dp"
        android:background="@color/bg_w" >

        <RadioButton
            android:id="@+id/rb_ip_auto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_get_ip"
            android:textSize="28sp" />

        <RadioButton
            android:id="@+id/rb_ip_follow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/use_follow_ip"
            android:textSize="28sp" />
    </RadioGroup>

    <Button
        android:id="@+id/bt_ok"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignRight="@+id/rl_dns"
        android:layout_marginRight="32dp"
        android:background="@drawable/selector_button"
		android:textColor="#fff"
        android:text="@string/ok" />

</RelativeLayout>