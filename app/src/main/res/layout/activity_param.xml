<RelativeLayout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
   >

    <include
        android:id="@+id/title"
        layout="@layout/title" />

    <TextView
        android:id="@+id/tv_sys_set"
        style="@style/text_set"
        android:layout_width="360dp"
        android:layout_height="10dp"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="39dp"
        android:layout_below="@id/title"
        android:background="@color/bg_gray"
        android:gravity="center"
        android:text="@string/system_setup"
        android:visibility="invisible"
        android:textSize="@dimen/text_size" />

    <RadioGroup
        android:id="@+id/rg_setup"
        android:layout_width="360dp"
        android:layout_height="match_parent"
        android:layout_alignParentLeft="true"
        android:layout_marginLeft="38dp"
        android:layout_marginBottom="30dp"
        android:layout_below="@+id/tv_sys_set"
        android:layout_above="@+id/bottom"
        android:layerType="software"
        android:orientation="vertical" >
        
        <RadioButton
            android:id="@+id/rb_users"
            style="@style/rb_setup"
            android:checked="true"
            android:saveEnabled="false"
            android:drawableStart="@drawable/user_set"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text="@string/user_set" />
        <View 
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>

        <RadioButton
            android:id="@+id/rb_projs"
            style="@style/rb_setup"
            android:checked="true"
            android:saveEnabled="false"
            android:drawableStart="@drawable/normal_set"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text="检测项目" />
        <View 
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>

        <RadioButton
            android:id="@+id/rb_species"
            style="@style/rb_setup"
            android:checked="true"
            android:saveEnabled="false"
            android:drawableStart="@drawable/normal_set"
            android:drawableRight="@drawable/arrow"
            android:paddingLeft="80dp"
            android:paddingRight="15dp"
            android:text="样品信息" />
        <View 
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>

        <RadioButton
            android:id="@+id/rb_sources"
            style="@style/rb_setup"
            android:checked="false"
            android:saveEnabled="false"
            android:drawableStart="@drawable/wifi_set"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text="样品来源"/>
        <View 
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>
        <RadioButton
            android:id="@+id/rb_limits"
            style="@style/rb_setup"
            android:checked="false"
            android:saveEnabled="false"
            android:drawableStart="@drawable/limit"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text="参考限值"/>
        <View 
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>
        <RadioButton
            android:id="@+id/rb_tc_limits"
            style="@style/rb_setup"
            android:checked="false"
            android:saveEnabled="false"
            android:drawableStart="@drawable/limit"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text=" T/C 限值"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>
        <RadioButton
            android:id="@+id/rb_function"
            style="@style/rb_setup"
            android:checked="false"
            android:saveEnabled="false"
            android:drawableStart="@drawable/function"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text="标准曲线"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dashed"/>
        <RadioButton
            android:id="@+id/rb_guobiao"
            style="@style/rb_setup"
            android:checked="false"
            android:saveEnabled="false"
            android:drawableStart="@drawable/guobiao"
            android:paddingLeft="80dp"
            android:paddingRight="60dp"
            android:text="国标设置"/>
    </RadioGroup>

    <View 
        android:id="@+id/devider"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_toEndOf="@+id/rg_setup"
        android:layout_below="@+id/title"
        android:layout_above="@+id/bottom"
        android:layout_marginTop="2dp"
        android:background="#B2A8A7"/>
    <FrameLayout
        android:id="@+id/fl_set"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp"
        android:layout_marginRight="38dp"
        android:layout_below="@+id/title"
        android:layout_above="@+id/bottom"
        android:layout_toEndOf="@+id/devider"
        android:background="@null"/>
 <include 
        android:id="@+id/bottom"
        layout="@layout/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        />
</RelativeLayout>
