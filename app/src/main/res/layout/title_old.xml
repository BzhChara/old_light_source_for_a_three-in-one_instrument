<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@null"
    android:keepScreenOn="true">

    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="5dp"
        android:background="@null" >

        <com.zkzk.pra.ui.BatteryView
            android:id="@+id/battery"
            android:layout_width="50dp"
            android:layout_height="25dp"
            android:layout_centerVertical="true"
            android:layout_marginRight="5dp"
            android:layout_toLeftOf="@+id/iv_title_wifi" />

        <com.zkzk.pra.ui.Clock
            android:id="@+id/clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginRight="40dp"
            android:layout_toLeftOf="@+id/battery"
            android:textColor="@color/bg_w"
            android:textSize="25sp"
            android:typeface="serif" />

        <ImageView
            android:id="@+id/iv_title_wifi"
            android:layout_width="35dp"
            android:layout_height="25dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:scaleType="fitCenter"
            android:contentDescription="@string/wifi"
            android:src="@drawable/stat_sys_wifi_signal_0" />

        <Button
            android:id="@+id/bt_title_home"
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="36dp"
            android:layout_marginTop="-12dp"
            android:background="@drawable/selector_home"
            android:paddingTop="12dp"
            android:text="HOME"
            android:textColor="#00C0B2"
            android:textSize="30sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/bt_help"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/clock"
            android:background="@null"
            android:text="@string/help"
            android:textColor="#fff" />

        <ImageButton
            android:id="@+id/ib_title_back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="120dp"
            android:layout_toStartOf="@+id/clock"
            android:background="@null"
            android:scaleType="fitXY"
            android:src="@drawable/ib_back"/>
        
        <TextView 
            android:id="@+id/tv_title_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_w"
            android:layout_centerInParent="true"
            android:textSize="22sp"
            android:text="酶片孵育剩余时间："/>

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/ll_title_notice"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@null"
        android:orientation="horizontal"
        android:paddingLeft="500dp">
        <!-- 中科logo的paddingLeft是420dp -->
        <View 
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:text="@string/notice"
            android:background="#fff"/>
        <TextView 
            android:id="@+id/tv_title_notice"
            android:layout_height="match_parent"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:textSize="24sp"
            android:paddingStart="15dp"
            android:singleLine="true"  
	        android:ellipsize="marquee"  
	        android:marqueeRepeatLimit="marquee_forever"  
	        android:text="  "
            android:textColor="#fff"/>
        
    </LinearLayout>

</LinearLayout>